{
    "manifest_version": 3,
    "name": "Aha Collector",
    "version": "1.0.0",
    "description": "Save markdown notes from any webpage or video to Feishu Bitable.",
    "permissions": [
        "sidePanel",
        "storage",
        "tabs",
        "activeTab",
        "contextMenus",
        "scripting"
    ],
    "host_permissions": [
        "https://open.feishu.cn/*",
        "<all_urls>"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://x.com/*",
                "https://twitter.com/*",
                "https://www.reddit.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_title": "Open Side Panel",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "options_page": "options.html",
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}